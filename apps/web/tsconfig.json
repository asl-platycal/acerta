{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "paths": {
      "@/*": ["src/*"],
      "@acerta/core": ["../../core/index.ts"],
      "@acerta/core/*": ["../../core/*"],
      "@acerta/shared": ["../../shared/index.ts"],
      "@acerta/shared/*": ["../../shared/*"],
      "@acerta/services": ["../../services/index.ts"],
      "@acerta/services/*": ["../../services/*"],
      "@acerta/backend/*": ["../../backend/*"],
      "@acerta/tests/*": ["../../tests/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "../../core/**/*.ts",
    "../../shared/**/*.ts",
    "../../services/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "../../tests/**"]
}
